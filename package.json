{
  "name": "@patrikbreitenmoser/x-cli",
  "version": "1.0.2",
  "description": "CLI tool for querying the X (Twitter) API v2",
  "type": "module",
  "license": "MIT",
  "author": "Patrik Breitenmoser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrikbreitenmoser/x-cli.git"
  },
  "homepage": "https://github.com/patrikbreitenmoser/x-cli#readme",
  "bugs": {
    "url": "https://github.com/patrikbreitenmoser/x-cli/issues"
  },
  "keywords": [
    "x",
    "twitter",
    "cli",
    "api",
    "tweets",
    "bookmarks"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "x-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test dist/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@xdevplatform/xdk": "^0.5.0",
    "commander": "^14.0.3",
    "twitter-api-v2": "^1.28.0"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
